{
  "info": {
    "name": "AmakTech SmartExpense AI API",
    "description": "Complete API collection for SmartExpense. Set baseUrl variable to http://localhost:5000",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",      "value": "http://localhost:5000/api/v1" },
    { "key": "accessToken",  "value": "" },
    { "key": "refreshToken", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "http://localhost:5000/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [{ "listen": "test", "script": { "exec": [
            "const d = pm.response.json().data;",
            "pm.collectionVariables.set('accessToken',  d.accessToken);",
            "pm.collectionVariables.set('refreshToken', d.refreshToken);",
            "pm.test('Status 201', () => pm.response.to.have.status(201));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"Test@123456\"\n}" }
          }
        },
        {
          "name": "Login",
          "event": [{ "listen": "test", "script": { "exec": [
            "const d = pm.response.json().data;",
            "pm.collectionVariables.set('accessToken',  d.accessToken);",
            "pm.collectionVariables.set('refreshToken', d.refreshToken);",
            "pm.test('Status 200', () => pm.response.to.have.status(200));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"Test@123456\"\n}" }
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/auth/profile"
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/refresh",
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/logout",
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Transactions",
      "item": [
        {
          "name": "Create Income",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/transactions",
            "body": { "mode": "raw", "raw": "{\n  \"type\": \"INCOME\",\n  \"amount\": 500000,\n  \"category\": \"Salary\",\n  \"description\": \"Monthly salary\"\n}" }
          }
        },
        {
          "name": "Create Expense",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/transactions",
            "body": { "mode": "raw", "raw": "{\n  \"type\": \"EXPENSE\",\n  \"amount\": 35000,\n  \"category\": \"Food\",\n  \"description\": \"Weekly groceries\"\n}" }
          }
        },
        {
          "name": "Get All Transactions",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/transactions?page=1&limit=20&sortBy=date&sortOrder=desc", "query": [
              { "key": "page", "value": "1" }, { "key": "limit", "value": "20" },
              { "key": "sortBy", "value": "date" }, { "key": "sortOrder", "value": "desc" }
            ]}
          }
        },
        {
          "name": "Get Transactions (Filtered by Type)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/transactions?type=EXPENSE"
          }
        },
        {
          "name": "Financial Summary",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/transactions/summary"
          }
        },
        {
          "name": "Category Breakdown",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/transactions/breakdown?type=EXPENSE"
          }
        },
        {
          "name": "Monthly Trend",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/transactions/trend?months=6"
          }
        }
      ]
    },
    {
      "name": "Budgets",
      "item": [
        {
          "name": "Create Budget",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/budgets",
            "body": { "mode": "raw", "raw": "{\n  \"category\": \"Food\",\n  \"limit\": 80000,\n  \"period\": \"MONTHLY\",\n  \"startDate\": \"2025-01-01T00:00:00.000Z\",\n  \"endDate\": \"2025-01-31T23:59:59.000Z\"\n}" }
          }
        },
        {
          "name": "Get All Budgets",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/budgets"
          }
        },
        {
          "name": "Budget Dashboard",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/budgets/dashboard"
          }
        },
        {
          "name": "Active Budgets",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/budgets/active"
          }
        }
      ]
    },
    {
      "name": "AI",
      "item": [
        {
          "name": "Get AI Insights",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/ai/insights"
          }
        },
        {
          "name": "AI Chat",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/ai/chat",
            "body": { "mode": "raw", "raw": "{\n  \"message\": \"Am I spending too much on food this month?\"\n}" }
          }
        }
      ]
    }
  ]
}
